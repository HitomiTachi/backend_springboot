# Active profile: dev | test | prod
SPRING_PROFILES_ACTIVE=dev

# Server
SERVER_PORT=8080

# Database
DB_URL=jdbc:mysql://localhost:3306/webbandienthoai
DB_USERNAME=root
DB_PASSWORD=

# Auth / Security
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRATION_MS=86400000
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Uploads
UPLOAD_DIR=uploads
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=10MB

# Optional AI integration
GEMINI_API_KEY=

# Gmail SMTP (không commit giá trị thật)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_APP_PASSWORD=
MAIL_ENABLED=true

# VNPay sandbox (dev): bật khi có TMN + hash secret
VNPAY_ENABLED=false
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# Google OAuth
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
GOOGLE_FRONTEND_SUCCESS_URL=http://localhost:3000/#/oauth/google/callback
GOOGLE_FRONTEND_FAILURE_URL=http://localhost:3000/login
GOOGLE_ALLOWED_REDIRECT_URIS=http://localhost:3000/#/oauth/google/callback,http://127.0.0.1:3000/#/oauth/google/callback
